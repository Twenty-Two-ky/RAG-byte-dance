# 忽略 Git 相关
.git
.gitignore

# 忽略 IDE 配置
.idea
.vscode
.cursor
.trae

# 忽略 Python 缓存
__pycache__
*.pyc
*.pyo
*.pyd

# 忽略本地虚拟环境 (非常重要，否则镜像会巨大)
venv/
env/
anaconda/
.conda/

# 忽略数据目录中的临时文件，但保留目录结构
# 注意：我们通常不希望把本地测试的向量库打包进镜像，让用户自己挂载
data/vector_db/
data/raw_files/
data/user_config.json
# 但是要保留 data 目录本身
!data/.keep

# 忽略文档文件 (可选，减小镜像体积)
!data/.gitkeep
*.pdf